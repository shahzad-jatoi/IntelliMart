# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecommerce_classifier?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# ML Service (Render URL in production)
MODEL_SERVICE_URL=http://localhost:8000

# Frontend URL (Vercel URL in production — needed for CORS)
FRONTEND_URL=http://localhost:5173

# Email (for OTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
